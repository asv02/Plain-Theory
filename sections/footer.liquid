<footer class="pt-footer">
  <div class="pt-footer__inner">

    <div class="pt-footer__top">

      <div class="pt-footer__brand">
        <div class="pt-footer__logo">Plain Theory</div>
        <p class="pt-footer__tagline">240 GSM oversized tees for people who buy fewer, better things. Based in Delhi NCR.</p>
        <div class="pt-footer__socials">
          <a href="https://instagram.com" class="pt-footer__soc" target="_blank">Instagram</a>
          <a href="https://wa.me" class="pt-footer__soc" target="_blank">WhatsApp</a>
        </div>
      </div>

      <div class="pt-footer__col">
        <p class="pt-footer__col-title">Shop</p>
        <a href="/collections/all" class="pt-footer__link">All tees</a>
        <a href="/collections/all?filter=Washed+Black" class="pt-footer__link">Washed Black</a>
        <a href="/collections/all?filter=Vintage+Cream" class="pt-footer__link">Vintage Cream</a>
        <a href="/collections/all?filter=Military+Olive" class="pt-footer__link">Military Olive</a>
        <a href="/collections/all?filter=Storm+Slate" class="pt-footer__link">Storm Slate</a>
      </div>

      <div class="pt-footer__col">
        <p class="pt-footer__col-title">Info</p>
        <a href="/pages/about" class="pt-footer__link">About us</a>
        <a href="/pages/size-guide" class="pt-footer__link">Size guide</a>
        <a href="/pages/fabric-story" class="pt-footer__link">Fabric story</a>
        <a href="/pages/faq" class="pt-footer__link">FAQ</a>
      </div>

      <div class="pt-footer__col">
        <p class="pt-footer__col-title">Support</p>
        <a href="/pages/contact" class="pt-footer__link">Contact us</a>
        <a href="/policies/shipping-policy" class="pt-footer__link">Shipping policy</a>
        <a href="/policies/refund-policy" class="pt-footer__link">Returns & exchanges</a>
        <a href="/apps/tracktor" class="pt-footer__link">Track order</a>
      </div>

    </div>

    <div class="pt-footer__bottom">
      <p class="pt-footer__copy">© {{ 'now' | date: '%Y' }} Plain Theory. All rights reserved.</p>
      <div class="pt-footer__bottom-links">
        <a href="/policies/privacy-policy" class="pt-footer__fine">Privacy policy</a>
        <a href="/policies/terms-of-service" class="pt-footer__fine">Terms of service</a>
      </div>
    </div>

  </div>
</footer>

<style>
.pt-footer{
  background:#0F0E0C;
  border-top:1px solid rgba(201,168,76,0.12);
  padding:56px 48px 28px;
}
.pt-footer__inner{
  max-width:1400px;
  margin:0 auto;
}
.pt-footer__top{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1fr;
  gap:48px;
  margin-bottom:48px;
}
.pt-footer__logo{
  font-family:'Playfair Display',serif;
  font-size:18px;
  color:#C9A84C;
  letter-spacing:0.15em;
  text-transform:uppercase;
  margin-bottom:12px;
}
.pt-footer__tagline{
  font-size:12px;
  color:#6B6155;
  line-height:1.7;
  max-width:220px;
  font-weight:300;
  font-family:'DM Sans',sans-serif;
  margin-bottom:20px;
}
.pt-footer__socials{
  display:flex;
  gap:20px;
}
.pt-footer__soc{
  font-size:11px;
  color:#6B6155;
  text-decoration:none;
  letter-spacing:0.08em;
  text-transform:uppercase;
  font-family:'DM Sans',sans-serif;
  transition:color 0.2s;
}
.pt-footer__soc:hover{
  color:#C9A84C;
}
.pt-footer__col-title{
  font-size:10px;
  letter-spacing:0.16em;
  text-transform:uppercase;
  color:#9C9080;
  margin-bottom:16px;
  font-family:'DM Sans',sans-serif;
  font-weight:500;
}
.pt-footer__link{
  display:block;
  font-size:12px;
  color:#6B6155;
  text-decoration:none;
  margin-bottom:10px;
  font-family:'DM Sans',sans-serif;
  transition:color 0.2s;
}
.pt-footer__link:hover{
  color:#C9A84C;
}
.pt-footer__bottom{
  display:flex;
  justify-content:space-between;
  align-items:center;
  border-top:1px solid rgba(201,168,76,0.1);
  padding-top:24px;
}
.pt-footer__copy{
  font-size:11px;
  color:#4a4540;
  letter-spacing:0.06em;
  font-family:'DM Sans',sans-serif;
  margin:0;
}
.pt-footer__bottom-links{
  display:flex;
  gap:24px;
}
.pt-footer__fine{
  font-size:11px;
  color:#4a4540;
  text-decoration:none;
  letter-spacing:0.06em;
  font-family:'DM Sans',sans-serif;
  transition:color 0.2s;
}
.pt-footer__fine:hover{
  color:#6B6155;
}
@media(max-width:900px){
  .pt-footer__top{grid-template-columns:1fr 1fr;gap:32px}
  .pt-footer{padding:48px 24px 24px}
}
@media(max-width:540px){
  .pt-footer__top{grid-template-columns:1fr}
  .pt-footer__bottom{flex-direction:column;gap:16px;text-align:center}
}
</style>

