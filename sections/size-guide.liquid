<section class="pt-sg-hero">
  <div class="pt-sg-hero__content">
    <p class="pt-sg-eye">Fit guide</p>
    <h1 class="pt-sg-hero__h1">Find your size.<br><em>Get it right first time.</em></h1>
    <p class="pt-sg-hero__sub">Our tee is oversized by design. If you're between sizes, size down for a relaxed fit or stay true to size for a generous drape.</p>
  </div>
</section>

<section class="pt-sg-body">
  <div class="pt-sg-inner">

    <!-- FIT NOTE -->
    <div class="pt-sg-note">
      <span class="pt-sg-note__icon">↓</span>
      <p class="pt-sg-note__text">This is an <strong>oversized fit</strong>. The measurements below are the actual garment measurements — not body measurements. Compare against a tee you already own for best results.</p>
    </div>

    <!-- SIZE TABLE -->
    <div class="pt-sg-block">
      <p class="pt-sg-block__eye">Garment measurements</p>
      <h2 class="pt-sg-block__title">Size chart</h2>
      <p class="pt-sg-block__sub">All measurements in centimetres (cm). Measure flat, double for full circumference where applicable.</p>

      <div class="pt-sg-table-wrap">
        <table class="pt-sg-table">
          <thead>
            <tr>
              <th>Size</th>
              <th>Chest</th>
              <th>Length</th>
              <th>Shoulder</th>
              <th>Sleeve</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="pt-sg-size-label">S</td>
              <td>54 cm</td>
              <td>70 cm</td>
              <td>52 cm</td>
              <td>22 cm</td>
            </tr>
            <tr class="pt-sg-tr-alt">
              <td class="pt-sg-size-label">M</td>
              <td>57 cm</td>
              <td>72 cm</td>
              <td>54 cm</td>
              <td>23 cm</td>
            </tr>
            <tr>
              <td class="pt-sg-size-label">L</td>
              <td>60 cm</td>
              <td>74 cm</td>
              <td>56 cm</td>
              <td>24 cm</td>
            </tr>
            <tr class="pt-sg-tr-alt">
              <td class="pt-sg-size-label">XL</td>
              <td>63 cm</td>
              <td>76 cm</td>
              <td>58 cm</td>
              <td>25 cm</td>
            </tr>
            <tr>
              <td class="pt-sg-size-label">XXL</td>
              <td>66 cm</td>
              <td>78 cm</td>
              <td>60 cm</td>
              <td>26 cm</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- HOW TO MEASURE -->
    <div class="pt-sg-block">
      <p class="pt-sg-block__eye">How to measure</p>
      <h2 class="pt-sg-block__title">Measure in four steps.</h2>
      <div class="pt-sg-steps">
        <div class="pt-sg-step">
          <span class="pt-sg-step__num">01</span>
          <div>
            <p class="pt-sg-step__title">Chest</p>
            <p class="pt-sg-step__body">Measure across the widest point of the chest, one inch below the armhole. Multiply by 2 for full circumference.</p>
          </div>
        </div>
        <div class="pt-sg-step">
          <span class="pt-sg-step__num">02</span>
          <div>
            <p class="pt-sg-step__title">Length</p>
            <p class="pt-sg-step__body">Measure from the highest point of the shoulder (at the neck seam) straight down to the bottom hem.</p>
          </div>
        </div>
        <div class="pt-sg-step">
          <span class="pt-sg-step__num">03</span>
          <div>
            <p class="pt-sg-step__title">Shoulder</p>
            <p class="pt-sg-step__body">Measure from shoulder seam to shoulder seam across the back, laid flat.</p>
          </div>
        </div>
        <div class="pt-sg-step">
          <span class="pt-sg-step__num">04</span>
          <div>
            <p class="pt-sg-step__title">Sleeve</p>
            <p class="pt-sg-step__body">Measure from the shoulder seam to the end of the sleeve hem. Our tee has a short drop-shoulder sleeve.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FIT GUIDE -->
    <div class="pt-sg-block">
      <p class="pt-sg-block__eye">Fit advice</p>
      <h2 class="pt-sg-block__title">Which size is right for you?</h2>
      <div class="pt-sg-fits">
        <div class="pt-sg-fit">
          <p class="pt-sg-fit__label">For a relaxed oversized look</p>
          <p class="pt-sg-fit__advice">Size down from your usual size. The tee will still be roomy but with a more controlled drape.</p>
        </div>
        <div class="pt-sg-fit">
          <p class="pt-sg-fit__label">For the intended drop-shoulder drape</p>
          <p class="pt-sg-fit__advice">Go true to size. This is how the tee was designed to be worn — generous through the body with a pronounced drop shoulder.</p>
        </div>
        <div class="pt-sg-fit">
          <p class="pt-sg-fit__label">For a very oversized look</p>
          <p class="pt-sg-fit__advice">Size up one. Works especially well for shorter heights where the extra length adds to the silhouette.</p>
        </div>
      </div>
    </div>

    <!-- CARE -->
    <div class="pt-sg-block">
      <p class="pt-sg-block__eye">Care instructions</p>
      <h2 class="pt-sg-block__title">Keep it right.</h2>
      <div class="pt-sg-care">
        <div class="pt-sg-care__item">
          <span class="pt-sg-care__icon">⟳</span>
          <p class="pt-sg-care__text">Machine wash cold (30°C). Warm water causes unnecessary stress on the fibres.</p>
        </div>
        <div class="pt-sg-care__item">
          <span class="pt-sg-care__icon">↓</span>
          <p class="pt-sg-care__text">Wash inside out to preserve the colour and surface of the fabric.</p>
        </div>
        <div class="pt-sg-care__item">
          <span class="pt-sg-care__icon">○</span>
          <p class="pt-sg-care__text">Tumble dry low or air dry flat. Avoid high heat — it can affect the pre-shrunk finish.</p>
        </div>
        <div class="pt-sg-care__item">
          <span class="pt-sg-care__icon">△</span>
          <p class="pt-sg-care__text">Iron on medium heat if needed. Do not iron directly on any print or label.</p>
        </div>
        <div class="pt-sg-care__item">
          <span class="pt-sg-care__icon">✕</span>
          <p class="pt-sg-care__text">Do not bleach. Do not dry clean.</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="pt-sg-cta">
      <h2 class="pt-sg-cta__title">Still not sure?</h2>
      <p class="pt-sg-cta__sub">Drop us a message and we'll help you pick the right size before you order.</p>
      <div class="pt-sg-cta__btns">
        <a href="/pages/contact" class="pt-sg-cta__btn-s">Contact us</a>
        <a href="/collections/all" class="pt-sg-cta__btn-p">Shop the tee</a>
      </div>
    </div>

  </div>
</section>

<style>
.pt-sg-hero{
  background:#121212;
  min-height:280px;
  display:flex;
  align-items:flex-end;
  padding:60px 48px;
  border-bottom:1px solid rgba(255,255,255,0.12);
  position:relative;
  overflow:hidden;
}
.pt-sg-hero::before{
  content:'';position:absolute;inset:0;
  background-image:
    repeating-linear-gradient(0deg,transparent,transparent 48px,rgba(255,255,255,0.03) 48px,rgba(255,255,255,0.03) 49px),
    repeating-linear-gradient(90deg,transparent,transparent 48px,rgba(255,255,255,0.03) 48px,rgba(255,255,255,0.03) 49px);
}
.pt-sg-hero__content{position:relative;z-index:1;max-width:620px}
.pt-sg-eye{
  font-size:10px;letter-spacing:0.22em;text-transform:uppercase;
  color:#FFFFFF;margin-bottom:14px;font-family:'DM Sans',sans-serif;
}
.pt-sg-hero__h1{
  font-family:'Playfair Display',serif!important;
  font-size:44px!important;font-weight:400!important;
  color:#FFFFFF!important;line-height:1.1!important;
  margin:0 0 16px!important;
}
.pt-sg-hero__h1 em{font-style:italic;color:#FFFFFF}
.pt-sg-hero__sub{
  font-size:13px;color:#B3B3B3;
  font-weight:300;line-height:1.7;
  font-family:'DM Sans',sans-serif;
}
.pt-sg-body{background:#121212;padding:64px 48px}
.pt-sg-inner{max-width:900px;margin:0 auto}
.pt-sg-note{
  background:#121212;
  border:1px solid rgba(255,255,255,0.2);
  border-left:3px solid #FFFFFF;
  border-radius:4px;
  padding:20px 24px;
  display:flex;gap:16px;align-items:flex-start;
  margin-bottom:56px;
}
.pt-sg-note__icon{
  color:#FFFFFF;font-size:18px;flex-shrink:0;margin-top:2px;
}
.pt-sg-note__text{
  font-size:13px;color:#B3B3B3;line-height:1.7;
  font-family:'DM Sans',sans-serif;margin:0;
}
.pt-sg-note__text strong{color:#FFFFFF;font-weight:500}
.pt-sg-block{margin-bottom:64px}
.pt-sg-block__eye{
  font-size:10px;letter-spacing:0.18em;text-transform:uppercase;
  color:#FFFFFF;margin-bottom:8px;font-family:'DM Sans',sans-serif;
}
.pt-sg-block__title{
  font-family:'Playfair Display',serif!important;
  font-size:28px!important;font-weight:400!important;
  color:#FFFFFF!important;margin:0 0 8px!important;
}
.pt-sg-block__sub{
  font-size:12px;color:#8C8C8C;
  font-family:'DM Sans',sans-serif;
  margin-bottom:28px;line-height:1.6;
}
.pt-sg-table-wrap{overflow-x:auto}
.pt-sg-table{
  width:100%;border-collapse:collapse;
  font-family:'DM Sans',sans-serif;
}
.pt-sg-table th{
  font-size:10px;letter-spacing:0.14em;text-transform:uppercase;
  color:#B3B3B3;font-weight:500;padding:14px 20px;
  border-bottom:1px solid rgba(255,255,255,0.2);
  text-align:left;background:#121212;
}
.pt-sg-table td{
  font-size:13px;color:#B3B3B3;
  padding:14px 20px;
  border-bottom:1px solid rgba(255,255,255,0.07);
}
.pt-sg-tr-alt td{background:rgba(255,255,255,0.02)}
.pt-sg-size-label{
  color:#FFFFFF!important;
  font-weight:500!important;
  font-family:'Playfair Display',serif!important;
  font-size:15px!important;
}
.pt-sg-steps{display:flex;flex-direction:column;gap:24px}
.pt-sg-step{display:flex;gap:20px;align-items:flex-start}
.pt-sg-step__num{
  font-family:'Playfair Display',serif;font-size:20px;
  color:rgba(255,255,255,0.3);flex-shrink:0;width:32px;
  margin-top:1px;
}
.pt-sg-step__title{
  font-size:13px;color:#FFFFFF;font-weight:500;
  margin:0 0 4px;font-family:'DM Sans',sans-serif;
}
.pt-sg-step__body{
  font-size:12px;color:#8C8C8C;line-height:1.7;
  margin:0;font-family:'DM Sans',sans-serif;
}
.pt-sg-fits{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.pt-sg-fit{
  background:#121212;
  border:1px solid rgba(255,255,255,0.12);
  border-radius:6px;padding:24px;
  transition:border-color 0.3s;
}
.pt-sg-fit:hover{border-color:rgba(255,255,255,0.28)}
.pt-sg-fit__label{
  font-size:12px;color:#FFFFFF;font-weight:500;
  margin:0 0 10px;font-family:'DM Sans',sans-serif;
  letter-spacing:0.04em;
}
.pt-sg-fit__advice{
  font-size:12px;color:#8C8C8C;line-height:1.7;
  margin:0;font-family:'DM Sans',sans-serif;
}
.pt-sg-care{display:flex;flex-direction:column;gap:16px}
.pt-sg-care__item{
  display:flex;gap:16px;align-items:flex-start;
  padding-bottom:16px;
  border-bottom:1px solid rgba(255,255,255,0.07);
}
.pt-sg-care__item:last-child{border-bottom:none;padding-bottom:0}
.pt-sg-care__icon{
  width:28px;height:28px;flex-shrink:0;
  background:#121212;border:1px solid rgba(255,255,255,0.2);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:11px;color:#FFFFFF;
  line-height:1;text-align:center;padding-top:1px;
}
.pt-sg-care__text{
  font-size:13px;color:#B3B3B3;line-height:1.7;
  margin:0;font-family:'DM Sans',sans-serif;padding-top:4px;
}
.pt-sg-cta{
  text-align:center;padding:56px 0 0;
  border-top:1px solid rgba(255,255,255,0.1);
}
.pt-sg-cta__title{
  font-family:'Playfair Display',serif!important;
  font-size:32px!important;font-weight:400!important;
  color:#FFFFFF!important;margin:0 0 8px!important;
}
.pt-sg-cta__sub{
  font-size:13px;color:#8C8C8C;margin-bottom:28px;
  font-family:'DM Sans',sans-serif;font-weight:300;
}
.pt-sg-cta__btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.pt-sg-cta__btn-p{
  padding:14px 36px;background:#FFFFFF;color:#121212;
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  font-weight:500;border-radius:2px;text-decoration:none;
  font-family:'DM Sans',sans-serif;transition:background 0.2s;
  display:inline-block;
}
.pt-sg-cta__btn-p:hover{background:#FFFFFF}
.pt-sg-cta__btn-s{
  padding:14px 36px;background:transparent;color:#B3B3B3;
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  border:1px solid rgba(255,255,255,0.2);border-radius:2px;
  text-decoration:none;font-family:'DM Sans',sans-serif;
  transition:border-color 0.2s,color 0.2s;display:inline-block;
}
.pt-sg-cta__btn-s:hover{border-color:#FFFFFF;color:#FFFFFF}
@media(max-width:900px){
  .pt-sg-hero{padding:40px 24px;min-height:220px}
  .pt-sg-hero__h1{font-size:32px!important}
  .pt-sg-body{padding:48px 24px}
  .pt-sg-fits{grid-template-columns:1fr}
}
@media(max-width:540px){
  .pt-sg-table th,.pt-sg-table td{padding:12px 14px;font-size:12px}
}
</style>

