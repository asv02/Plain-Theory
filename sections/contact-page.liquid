.pt-ct-business{
    max-width:760px;
    margin:36px auto 0;
    border-top:1px solid rgba(18,18,18,.08);
    padding-top:48px;
}

.pt-ct-collapse{
    border-bottom:1px solid rgba(18,18,18,.12);
}

.pt-ct-collapse summary{
    list-style:none;
    cursor:pointer;
    padding:14px 0;
    font-size:13px;
    font-family:'DM Sans',sans-serif;
    font-weight:500;
    display:flex;
    justify-content:space-between;
    align-items:center;
    transition:.25s;
}

.pt-ct-collapse summary::-webkit-details-marker{
    display:none;
}

.pt-ct-collapse summary::after{
    content:'›';
    font-size:18px;
    transition:transform .25s ease;
}


.pt-ct-collapse[open] summary::after{
    transform:rotate(90deg);
}

.pt-ct-collapse p{
    padding:0 0 20px;
    margin:0;
    font-size:13px;
    line-height:1.8;
    color:#121212;
    font-family:'DM Sans',sans-serif;
}

.pt-ct-collapse summary:hover{
    padding-left:8px;
}
.pt-ct-links-section{
    margin-top:56px;
}
.pt-business{
    max-width:760px;
    margin:56px auto;
}

.pt-section-label{
    font-size:11px;
    letter-spacing:.22em;
    text-transform:uppercase;
    margin-bottom:26px;
    font-family:'DM Sans',sans-serif;
}

.pt-item{
    border-top:1px solid rgba(18,18,18,.10);
}

.pt-item:last-child{
    border-bottom:1px solid rgba(18,18,18,.10);
}

.pt-trigger{
    width:100%;
    padding:22px 0;
    background:none;
    border:none;
    cursor:pointer;

    display:flex;
    justify-content:space-between;
    align-items:center;

    font-size:15px;
    font-family:'DM Sans',sans-serif;
    color:#121212;

    transition:.3s;
}

.pt-trigger:hover{
    color:#555;
}

.pt-icon{
    font-size:22px;
    transition:.35s;
    font-weight:300;
}

.pt-content{

    max-height:0;
    overflow:hidden;

    transition:max-height .45s ease;

}

.pt-content p{

    margin:0 0 22px;

    font-size:14px;

    line-height:1.9;

    color:#555;

    font-family:'DM Sans',sans-serif;

}
.pt-ct-section-header{

    max-width:760px;
    margin:0 auto 36px;

}

.pt-ct-section-title{

    font-family:'Playfair Display',serif;
    font-size:38px;
    font-weight:400;
    line-height:1.2;
    margin:0 0 14px;
    color:#121212;

}

.pt-ct-section-description{

    max-width:560px;

    font-size:15px;

    line-height:1.8;

    color:#555;

    font-family:'DM Sans',sans-serif;

}
</style>
<script>

document.querySelectorAll(".pt-trigger").forEach(button=>{

    button.addEventListener("click",()=>{

        const item=button.parentElement;

        const content=item.querySelector(".pt-content");

        const icon=item.querySelector(".pt-icon");

        const isOpen=item.classList.contains("active");

        document.querySelectorAll(".pt-item").forEach(i=>{

            i.classList.remove("active");

            i.querySelector(".pt-content").style.maxHeight=null;

            i.querySelector(".pt-icon").textContent="+";

        });

        if(!isOpen){

            item.classList.add("active");

            content.style.maxHeight=content.scrollHeight+"px";

            icon.textContent="−";

        }

    });

});

</script>

