{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account pt-account section-{{ section.id }}-padding">

  <div class="pt-account-header">

    <div>

      <p class="pt-eyebrow">
        Plain Thread
      </p>

      <h1 class="pt-title">
        Welcome back,
        {{ customer.first_name | default: 'Member' }}
      </h1>

      <p class="pt-subtitle">
        Manage your orders, addresses and account details.
      </p>

    </div>

    <a
      class="pt-logout"
      href="{{ routes.account_logout_url }}"
    >

      <span class="svg-wrapper">
        {{ 'icon-account.svg' | inline_asset_content }}
      </span>

      Logout

    </a>

  </div>

  <div class="pt-dashboard">

    <a
      href="#orders"
      class="pt-card"
    >

      <div class="pt-card-icon">
        📦
      </div>

      <div>

        <h3>
          Orders
        </h3>

        <p>

          {{ customer.orders_count }}

          Total Orders

        </p>

      </div>

    </a>

    <a
      href="{{ routes.account_addresses_url }}"
      class="pt-card"
    >

      <div class="pt-card-icon">
        📍
      </div>

      <div>

        <h3>
          Addresses
        </h3>

        <p>

          {{ customer.addresses_count }}

          Saved

        </p>

      </div>

    </a>

    <a
      href="https://orderstat.plainthread.in"
      target="_blank"
      class="pt-card"
    >

      <div class="pt-card-icon">
        🚚
      </div>

      <div>

        <h3>

          Track Order

        </h3>

        <p>

          Live Shipment Status

        </p>

      </div>

    </a>

    <a
      href="/pages/contact"
      class="pt-card"
    >

      <div class="pt-card-icon">
        💬
      </div>

      <div>

        <h3>

          Support

        </h3>

        <p>

          Need Help?

        </p>

      </div>

    </a>

  </div>

  <div
    class="pt-orders"
    id="orders"
  >

    <div class="pt-section-heading">

      <h2>

        Recent Orders

      </h2>

      <span>

        {{ customer.orders_count }}

        Orders

      </span>

    </div>

    {% paginate customer.orders by 20 %}
        {%- if customer.orders.size > 0 -%}

<div class="pt-order-list">

  {% for order in customer.orders %}

  <article class="pt-order-card">

    <div class="pt-order-top">

      <div>

        <span class="pt-order-label">
          Order
        </span>

        <h3>
          {{ order.name }}
        </h3>

      </div>

      <div class="pt-order-status">

        <span class="payment-status">

          {{ order.financial_status_label }}

        </span>

        <span class="fulfillment-status">

          {{ order.fulfillment_status_label }}

        </span>

      </div>

    </div>

    <div class="pt-order-meta">

      <div>

        <span>Date</span>

        <strong>

          {{ order.created_at | date: "%d %b %Y" }}

        </strong>

      </div>

      <div>

        <span>Total</span>

        <strong>

          {{ order.total_price | money }}

        </strong>

      </div>

      <div>

        <span>Items</span>

        <strong>

          {{ order.line_items.size }}

        </strong>

      </div>

    </div>

    <div class="pt-order-products">

      {% for line_item in order.line_items limit:2 %}

      <div class="pt-product-row">

        {% if line_item.image %}

        <img
          src="{{ line_item.image | image_url: width:120 }}"
          alt="{{ line_item.title }}"
          loading="lazy"
        >

        {% endif %}

        <div>

          <h4>

            {{ line_item.product.title }}

          </h4>

          <p>

            Qty {{ line_item.quantity }}

          </p>

          {% unless line_item.variant.title == 'Default Title' %}

          <small>

            {{ line_item.variant.title }}

          </small>

          {% endunless %}

        </div>

      </div>

      {% endfor %}

      {% if order.line_items.size > 2 %}

      <p class="pt-more-items">

        +{{ order.line_items.size | minus:2 }}

        more item(s)

      </p>

      {% endif %}

    </div>

    <div class="pt-order-actions">

      <a
        href="{{ order.customer_url }}"
        class="button"
      >

        View Details

      </a>

      <a
        href="https://orderstat.plainthread.in"
        target="_blank"
        class="button button--secondary"
      >

        Track Order

      </a>

      {% assign first_item = order.line_items.first %}

      {% if first_item.product %}

      <a
        href="{{ first_item.product.url }}"
        class="button button--tertiary"
      >

        Buy Again

      </a>

      {% endif %}

    </div>

  </article>

  {% endfor %}

</div>

{%- else -%}

<div class="pt-empty-state">

  <div class="pt-empty-icon">

    📦

  </div>

  <h2>

    Your wardrobe starts here

  </h2>

  <p>

    You haven't placed an order yet.

    Explore timeless oversized essentials designed for everyday comfort.

  </p>

  <a
    href="/collections/all"
    class="button"
  >

    Shop Collection

  </a>

</div>

{%- endif -%}

        {%- if paginate.pages > 1 -%}
          {%- if paginate.parts.size > 0 -%}
            <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
              <ul role="list">
                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                        {{- part.title -}}
                      </a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                          {{- part.title -}}
                        </span>
                      {%- else -%}
                        <span>{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </li>
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endif -%}
      {% endpaginate %}
    </div>

    <div>
      <h2>{{ 'customer.account.details' | t }}</h2>

      {{ customer.default_address | format_address }}

      <a href="{{ routes.account_addresses_url }}">
        {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
