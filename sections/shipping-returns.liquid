<section class="pt-sr-hero">
  <div class="pt-sr-hero__content">
    <p class="pt-sr-eye">Shipping & Returns</p>
    <h1 class="pt-sr-hero__h1">Simple policies.<br><em>No fine print.</em></h1>
    <p class="pt-sr-hero__sub">We keep it straightforward. Here's everything you need to know about getting your order and what to do if something isn't right.</p>
  </div>
</section>

<section class="pt-sr-body">
  <div class="pt-sr-inner">

    <!-- QUICK SUMMARY -->
    <div class="pt-sr-summary">
      <div class="pt-sr-sum-card">
        <span class="pt-sr-sum-card__icon">✦</span>
        <p class="pt-sr-sum-card__title">Free shipping</p>
        <p class="pt-sr-sum-card__body">On all orders above ₹999. Every Plain Theory order qualifies automatically.</p>
      </div>
      <div class="pt-sr-sum-card">
        <span class="pt-sr-sum-card__icon">◎</span>
        <p class="pt-sr-sum-card__title">1–2 day processing</p>
        <p class="pt-sr-sum-card__body">Orders are packed and dispatched within 1–2 business days of payment confirmation.</p>
      </div>
      <div class="pt-sr-sum-card">
        <span class="pt-sr-sum-card__icon">↺</span>
        <p class="pt-sr-sum-card__title">7-day exchanges</p>
        <p class="pt-sr-sum-card__body">Wrong size? We'll exchange it within 7 days of delivery — no hassle.</p>
      </div>
      <div class="pt-sr-sum-card">
        <span class="pt-sr-sum-card__icon">◈</span>
        <p class="pt-sr-sum-card__title">COD available</p>
        <p class="pt-sr-sum-card__body">Cash on delivery across most Indian pin codes. Select at checkout.</p>
      </div>
    </div>

    <!-- SHIPPING -->
    <div class="pt-sr-block">
      <div class="pt-sr-block__header">
        <p class="pt-sr-block__eye">Shipping</p>
        <h2 class="pt-sr-block__title">Delivery information</h2>
      </div>
      <div class="pt-sr-block__content">

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Processing time</div>
          <div class="pt-sr-row__value">Orders are processed within <strong>1–2 business days</strong> after payment confirmation. You'll receive a dispatch notification with tracking details via SMS and email.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Delhi NCR delivery</div>
          <div class="pt-sr-row__value"><strong>2–4 business days</strong> from dispatch. Most Delhi NCR orders arrive within 2–3 days.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Pan-India delivery</div>
          <div class="pt-sr-row__value"><strong>4–7 business days</strong> from dispatch. Remote pin codes may take up to 8–10 days.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Shipping charges</div>
          <div class="pt-sr-row__value"><strong>Free on all orders above ₹999.</strong> Since every Plain Theory tee is ₹1,499, every order ships free. A flat ₹99 shipping fee applies to orders below ₹999 (applicable if we introduce lower-priced products).</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Tracking</div>
          <div class="pt-sr-row__value">A tracking link is sent to your email and phone number as soon as your order is dispatched. You can also track your order at any time from our <a href="#" class="pt-sr-link">Track Order</a> page.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Cash on delivery</div>
          <div class="pt-sr-row__value">COD is available across most Indian pin codes. Select "Cash on Delivery" at checkout. Please note that COD orders take an additional <strong>1–2 days</strong> longer to process compared to prepaid orders. We recommend prepaid for faster dispatch.</div>
        </div>

        <div class="pt-sr-row pt-sr-row--last">
          <div class="pt-sr-row__label">International shipping</div>
          <div class="pt-sr-row__value">We currently ship within India only. International shipping is something we're working towards — sign up to our mailing list to be notified when it's available.</div>
        </div>

      </div>
    </div>

    <!-- RETURNS & EXCHANGES -->
    <div class="pt-sr-block">
      <div class="pt-sr-block__header">
        <p class="pt-sr-block__eye">Returns & Exchanges</p>
        <h2 class="pt-sr-block__title">What if something isn't right?</h2>
      </div>
      <div class="pt-sr-block__content">

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Size exchanges</div>
          <div class="pt-sr-row__value">If the size doesn't work, we'll exchange it. Contact us within <strong>7 days of delivery</strong> with your order number and the size you need. We'll check availability and arrange a pickup and redelivery.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Exchange conditions</div>
          <div class="pt-sr-row__value">The tee must be <strong>unworn, unwashed, and in original condition</strong> with tags intact. We inspect returned items before dispatching the replacement. Items that show signs of wear will not be accepted for exchange.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Refunds</div>
          <div class="pt-sr-row__value">We don't offer refunds for change of mind. If your order arrives damaged, defective, or incorrect, we'll issue a <strong>full refund or replacement</strong> — whichever you prefer — immediately after verification.</div>
        </div>

        <div class="pt-sr-row">
          <div class="pt-sr-row__label">Damaged or wrong items</div>
          <div class="pt-sr-row__value">Email us at <a href="mailto:hello@plaintheory.in" class="pt-sr-link">hello@plaintheory.in</a> within <strong>48 hours of delivery</strong> with your order number and a clear photo of the issue. We'll resolve it immediately — no back and forth.</div>
        </div>

        <div class="pt-sr-row pt-sr-row--last">
          <div class="pt-sr-row__label">Exchange timeline</div>
          <div class="pt-sr-row__value">Once we receive and inspect the returned item, your replacement is dispatched within <strong>2 business days</strong>. Standard delivery timelines apply for the replacement.</div>
        </div>

      </div>
    </div>

    <!-- HOW TO INITIATE -->
    <div class="pt-sr-block">
      <div class="pt-sr-block__header">
        <p class="pt-sr-block__eye">Process</p>
        <h2 class="pt-sr-block__title">How to raise an exchange request.</h2>
      </div>
      <div class="pt-sr-steps">
        <div class="pt-sr-step">
          <span class="pt-sr-step__num">01</span>
          <div>
            <p class="pt-sr-step__title">Contact us within 7 days</p>
            <p class="pt-sr-step__body">Email <a href="mailto:hello@plaintheory.in" class="pt-sr-link">hello@plaintheory.in</a> or WhatsApp us with your order number, the size you received, and the size you need.</p>
          </div>
        </div>
        <div class="pt-sr-step">
          <span class="pt-sr-step__num">02</span>
          <div>
            <p class="pt-sr-step__title">We confirm availability</p>
            <p class="pt-sr-step__body">We'll check stock for your requested size and confirm within 24 hours. If the size is unavailable, we'll offer a full refund instead.</p>
          </div>
        </div>
        <div class="pt-sr-step">
          <span class="pt-sr-step__num">03</span>
          <div>
            <p class="pt-sr-step__title">Pack and hand over</p>
            <p class="pt-sr-step__body">Pack the tee in its original packaging with tags intact. Our courier partner will pick it up from your address — no need to visit a post office.</p>
          </div>
        </div>
        <div class="pt-sr-step">
          <span class="pt-sr-step__num">04</span>
          <div>
            <p class="pt-sr-step__title">Replacement dispatched</p>
            <p class="pt-sr-step__body">Once received and inspected, your replacement is dispatched within 2 business days with a new tracking link.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="pt-sr-cta">
      <h2 class="pt-sr-cta__title">Need help with an order?</h2>
      <p class="pt-sr-cta__sub">We're available every day. Reach us by email or WhatsApp.</p>
      <div class="pt-sr-cta__btns">
        <a href="mailto:hello@plaintheory.in" class="pt-sr-cta__btn-p">Email us</a>
        <a href="https://wa.me/919XXXXXXXXX" class="pt-sr-cta__btn-s" target="_blank">WhatsApp us</a>
      </div>
    </div>

  </div>
</section>

<style>
.pt-sr-hero{
  background:#141210;min-height:280px;
  display:flex;align-items:flex-end;
  padding:60px 48px;
  border-bottom:1px solid rgba(201,168,76,0.12);
  position:relative;overflow:hidden;
}
.pt-sr-hero::before{
  content:'';position:absolute;inset:0;
  background-image:
    repeating-linear-gradient(0deg,transparent,transparent 48px,rgba(201,168,76,0.03) 48px,rgba(201,168,76,0.03) 49px),
    repeating-linear-gradient(90deg,transparent,transparent 48px,rgba(201,168,76,0.03) 48px,rgba(201,168,76,0.03) 49px);
}
.pt-sr-hero__content{position:relative;z-index:1;max-width:620px}
.pt-sr-eye{
  font-size:10px;letter-spacing:0.22em;text-transform:uppercase;
  color:#C9A84C;margin-bottom:14px;font-family:'DM Sans',sans-serif;
}
.pt-sr-hero__h1{
  font-family:'Playfair Display',serif!important;
  font-size:44px!important;font-weight:400!important;
  color:#E8E0D0!important;line-height:1.1!important;
  margin:0 0 16px!important;
}
.pt-sr-hero__h1 em{font-style:italic;color:#C9A84C}
.pt-sr-hero__sub{
  font-size:13px;color:#9C9080;font-weight:300;
  line-height:1.7;font-family:'DM Sans',sans-serif;max-width:480px;
}
.pt-sr-body{background:#0F0E0C;padding:64px 48px}
.pt-sr-inner{max-width:900px;margin:0 auto}
.pt-sr-summary{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:16px;margin-bottom:64px;
}
.pt-sr-sum-card{
  background:#141210;border:1px solid rgba(201,168,76,0.12);
  border-radius:6px;padding:24px;
  transition:border-color 0.3s;
}
.pt-sr-sum-card:hover{border-color:rgba(201,168,76,0.28)}
.pt-sr-sum-card__icon{
  display:block;font-size:18px;color:#C9A84C;
  margin-bottom:12px;
}
.pt-sr-sum-card__title{
  font-size:13px;color:#E8E0D0;font-weight:500;
  margin:0 0 6px;font-family:'DM Sans',sans-serif;
}
.pt-sr-sum-card__body{
  font-size:12px;color:#6B6155;line-height:1.6;
  margin:0;font-family:'DM Sans',sans-serif;
}
.pt-sr-block{margin-bottom:56px}
.pt-sr-block__header{margin-bottom:24px}
.pt-sr-block__eye{
  font-size:10px;letter-spacing:0.18em;text-transform:uppercase;
  color:#C9A84C;margin-bottom:8px;font-family:'DM Sans',sans-serif;
}
.pt-sr-block__title{
  font-family:'Playfair Display',serif!important;
  font-size:28px!important;font-weight:400!important;
  color:#E8E0D0!important;margin:0!important;
}
.pt-sr-block__content{
  background:#141210;border:1px solid rgba(201,168,76,0.1);
  border-radius:6px;overflow:hidden;
}
.pt-sr-row{
  display:grid;grid-template-columns:180px 1fr;
  gap:24px;padding:20px 24px;
  border-bottom:1px solid rgba(201,168,76,0.07);
}
.pt-sr-row--last{border-bottom:none}
.pt-sr-row__label{
  font-size:11px;color:#C9A84C;font-weight:500;
  text-transform:uppercase;letter-spacing:0.08em;
  font-family:'DM Sans',sans-serif;padding-top:1px;
}
.pt-sr-row__value{
  font-size:13px;color:#9C9080;line-height:1.8;
  font-family:'DM Sans',sans-serif;font-weight:300;
}
.pt-sr-row__value strong{color:#E8E0D0;font-weight:500}
.pt-sr-link{
  color:#C9A84C;text-decoration:none;
  border-bottom:1px solid rgba(201,168,76,0.3);
  transition:border-color 0.2s;
}
.pt-sr-link:hover{border-color:#C9A84C}
.pt-sr-steps{display:flex;flex-direction:column;gap:24px}
.pt-sr-step{display:flex;gap:20px;align-items:flex-start}
.pt-sr-step__num{
  font-family:'Playfair Display',serif;font-size:20px;
  color:rgba(201,168,76,0.3);flex-shrink:0;width:32px;
  margin-top:1px;
}
.pt-sr-step__title{
  font-size:13px;color:#E8E0D0;font-weight:500;
  margin:0 0 4px;font-family:'DM Sans',sans-serif;
}
.pt-sr-step__body{
  font-size:12px;color:#6B6155;line-height:1.7;
  margin:0;font-family:'DM Sans',sans-serif;
}
.pt-sr-cta{
  text-align:center;padding:56px 0 0;
  border-top:1px solid rgba(201,168,76,0.1);
}
.pt-sr-cta__title{
  font-family:'Playfair Display',serif!important;
  font-size:32px!important;font-weight:400!important;
  color:#E8E0D0!important;margin:0 0 8px!important;
}
.pt-sr-cta__sub{
  font-size:13px;color:#6B6155;margin-bottom:28px;
  font-family:'DM Sans',sans-serif;font-weight:300;
}
.pt-sr-cta__btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.pt-sr-cta__btn-p{
  padding:14px 36px;background:#C9A84C;color:#0F0E0C;
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  font-weight:500;border-radius:2px;text-decoration:none;
  font-family:'DM Sans',sans-serif;transition:background 0.2s;
  display:inline-block;
}
.pt-sr-cta__btn-p:hover{background:#E8C97A}
.pt-sr-cta__btn-s{
  padding:14px 36px;background:transparent;color:#9C9080;
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  border:1px solid rgba(201,168,76,0.2);border-radius:2px;
  text-decoration:none;font-family:'DM Sans',sans-serif;
  transition:border-color 0.2s,color 0.2s;display:inline-block;
}
.pt-sr-cta__btn-s:hover{border-color:#C9A84C;color:#C9A84C}
@media(max-width:900px){
  .pt-sr-summary{grid-template-columns:repeat(2,1fr)}
  .pt-sr-row{grid-template-columns:1fr;gap:8px}
  .pt-sr-row__label{font-size:10px}
}
@media(max-width:540px){
  .pt-sr-hero{padding:40px 24px;min-height:220px}
  .pt-sr-hero__h1{font-size:32px!important}
  .pt-sr-body{padding:48px 24px}
  .pt-sr-summary{grid-template-columns:1fr}
}
</style>

