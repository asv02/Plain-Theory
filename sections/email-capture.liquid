<section class="pt-em">
  <div class="pt-em__inner">
    <h2 class="pt-em__title">Drop alerts. Nothing else.</h2>
    <p class="pt-em__sub">New colours, restocks, and early access — straight to your inbox</p>

    {% form 'customer', id: 'pt-email-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="pt-em__form">
        <input
          class="pt-em__input"
          type="email"
          name="contact[email]"
          placeholder="your@email.com"
          required
          autocomplete="email"
        >
        <button type="submit" class="pt-em__btn">Join the list</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="pt-em__success">You're in. We'll be in touch.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="pt-em__error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
      {%- endif -%}
    {% endform %}

    <p class="pt-em__note">No spam. No fluff. Unsubscribe anytime.</p>
  </div>
</section>

<style>
.pt-em{
  background:#0F0E0C;
  padding:80px 48px;
  text-align:center;
  border-top:1px solid rgba(201,168,76,0.1);
}
.pt-em__inner{
  max-width:560px;
  margin:0 auto;
}
.pt-em__title{
  font-family:'Playfair Display',serif!important;
  font-size:36px!important;
  font-weight:400!important;
  color:#E8E0D0!important;
  margin:0 0 10px!important;
  letter-spacing:0!important;
}
.pt-em__sub{
  font-size:13px;
  color:#6B6155;
  letter-spacing:0.06em;
  margin-bottom:32px;
  font-weight:300;
  font-family:'DM Sans',sans-serif;
}
.pt-em__form{
  display:flex;
  gap:0;
  max-width:420px;
  margin:0 auto 16px;
}
.pt-em__input{
  flex:1;
  background:#1e1b17!important;
  border:1px solid rgba(201,168,76,0.15)!important;
  border-right:none!important;
  color:#E8E0D0!important;
  padding:14px 18px!important;
  font-size:13px!important;
  font-family:'DM Sans',sans-serif!important;
  outline:none!important;
  border-radius:2px 0 0 2px!important;
  transition:border-color 0.2s!important;
  box-shadow:none!important;
  height:auto!important;
  min-height:auto!important;
}
.pt-em__input:focus{
  border-color:rgba(201,168,76,0.4)!important;
}
.pt-em__input::placeholder{
  color:#4a4540!important;
  opacity:1!important;
}
.pt-em__btn{
  background:#C9A84C!important;
  color:#0F0E0C!important;
  padding:14px 28px!important;
  font-size:11px!important;
  letter-spacing:0.14em!important;
  text-transform:uppercase!important;
  font-weight:500!important;
  cursor:pointer!important;
  border:none!important;
  border-radius:0 2px 2px 0!important;
  font-family:'DM Sans',sans-serif!important;
  transition:background 0.2s!important;
  white-space:nowrap!important;
  min-width:0!important;
  min-height:auto!important;
}
.pt-em__btn:hover{
  background:#E8C97A!important;
  color:#0F0E0C!important;
}
.pt-em__note{
  font-size:10px;
  color:#4a4540;
  letter-spacing:0.08em;
  margin:0;
  font-family:'DM Sans',sans-serif;
}
.pt-em__success{
  color:#C9A84C;
  font-size:13px;
  font-family:'DM Sans',sans-serif;
  margin-bottom:12px;
}
.pt-em__error{
  color:#9C9080;
  font-size:12px;
  font-family:'DM Sans',sans-serif;
  margin-bottom:12px;
}
@media(max-width:540px){
  .pt-em{padding:56px 24px}
  .pt-em__form{flex-direction:column;gap:8px}
  .pt-em__input{
    border-right:1px solid rgba(201,168,76,0.15)!important;
    border-radius:2px!important;
  }
  .pt-em__btn{border-radius:2px!important;width:100%!important}
}
</style>

{% schema %}
{
  "name": "Email capture",
  "settings": [],
  "presets": [{ "name": "Email capture" }]
}
{% endschema %}