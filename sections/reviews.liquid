<section class="pt-rv">
  <div class="pt-rv__inner">

    <div class="pt-rv__header">
      <div>
        <p class="pt-rv__eye">What they said</p>
        <h2 class="pt-rv__title">Real orders. Real people.</h2>
      </div>
      <div class="pt-rv__overall">
        <span class="pt-rv__stars">★★★★★</span>
        <span class="pt-rv__score">Verified buyer reviews</span>
      </div>
    </div>

    <div class="pt-rv__list">
      {%- for block in section.blocks -%}
        <figure class="pt-rv__item" {{ block.shopify_attributes }}>
          <blockquote class="pt-rv__text">{{ block.settings.text }}</blockquote>
          <figcaption class="pt-rv__by">by {{ block.settings.author }}</figcaption>
        </figure>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
.pt-rv{
  background:#F7F5EF;
  padding:80px 48px;
}
.pt-rv__inner{
  max-width:1400px;
  margin:0 auto;
}
.pt-rv__header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  margin-bottom:48px;
  padding-bottom:32px;
  border-bottom:1px solid rgba(18,18,18,0.12);
}
.pt-rv__eye{
  font-size:10px;
  letter-spacing:0.18em;
  text-transform:uppercase;
  color:#121212;
  margin-bottom:8px;
  font-family:'DM Sans',sans-serif;
}
.pt-rv__title{
  font-family:'Playfair Display',serif!important;
  font-size:32px!important;
  font-weight:400!important;
  color:#121212!important;
  margin:0!important;
  letter-spacing:0!important;
}
.pt-rv__overall{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:4px;
}
.pt-rv__stars{
  color:#121212;
  font-size:14px;
  letter-spacing:3px;
}
.pt-rv__score{
  font-size:12px;
  color:#121212;
  font-family:'DM Sans',sans-serif;
}
.pt-rv__list{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:32px 40px;
}
.pt-rv__item{
  margin:0;
}
.pt-rv__text{
  font-family:'DM Sans',sans-serif;
  font-size:14px;
  line-height:1.75;
  color:#121212;
  margin:0 0 12px;
  font-weight:300;
}
.pt-rv__by{
  font-family:'DM Sans',sans-serif;
  font-size:11px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:rgba(18,18,18,0.55);
  margin:0;
}
@media(max-width:900px){
  .pt-rv{padding:56px 24px}
  .pt-rv__header{flex-direction:column;align-items:flex-start;gap:12px}
  .pt-rv__list{grid-template-columns:repeat(2,minmax(0,1fr));gap:28px}
}
@media(max-width:540px){
  .pt-rv__list{grid-template-columns:1fr;gap:24px}
}
</style>

{% schema %}
{
  "name": "Reviews",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "The 220 GSM fabric feels noticeably heavier than my other tees. Worth every rupee."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Username",
          "default": "Arjun K."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "The 220 GSM fabric feels noticeably heavier than my other tees. Worth every rupee.",
            "author": "Arjun K."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Ordered the black one — fit is exactly as described. Slightly oversized, sits well.",
            "author": "Priya M."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Finally a plain tee that doesn't feel cheap after two washes. The rose pink colour is perfect.",
            "author": "Neha S."
          }
        }
      ]
    }
  ]
}
{% endschema %}
