<section class="pt-rv">
  <div class="pt-rv__inner">

    <div class="pt-rv__header">
      <div>
        <p class="pt-rv__eye">What they said</p>
        <h2 class="pt-rv__title">Real orders. Real people.</h2>
      </div>
      <div class="pt-rv__overall">
        <span class="pt-rv__stars">★★★★★</span>
        <span class="pt-rv__score">Verified buyer reviews</span>
      </div>
    </div>
    {% render 'judgeme_widgets', widget_type: 'judgeme_all_reviews_widget', concierge_install: true %}

  </div>
</section>

<style>
.pt-rv{k
  background:#121212;
  padding:80px 48px;
}
.pt-rv__inner{
  max-width:1400px;
  margin:0 auto;
}
.pt-rv__header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  margin-bottom:48px;
}
.pt-rv__eye{
  font-size:10px;
  letter-spacing:0.18em;
  text-transform:uppercase;
  color:#FFFFFF;
  margin-bottom:8px;
  font-family:'DM Sans',sans-serif;
}
.pt-rv__title{
  font-family:'Playfair Display',serif!important;
  font-size:32px!important;
  font-weight:400!important;
  color:#FFFFFF!important;
  margin:0!important;
  letter-spacing:0!important;
}
.pt-rv__overall{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:4px;
}
.pt-rv__stars{
  color:#FFFFFF;
  font-size:14px;
  letter-spacing:3px;
}
.pt-rv__score{
  font-size:12px;
  color:#8C8C8C;
  font-family:'DM Sans',sans-serif;
}

/* Judge.me widget overrides — match Plain Theory dark theme */
.jdgm-all-reviews-widget,
.jdgm-widget{
  background:transparent!important;
  color:#FFFFFF!important;
  font-family:'DM Sans',sans-serif!important;
}
.jdgm-rev{
  background:#121212!important;
  border:1px solid rgba(255,255,255,0.12)!important;
  border-radius:6px!important;
  padding:24px!important;
  margin-bottom:16px!important;
}
.jdgm-rev:hover{
  border-color:rgba(255,255,255,0.28)!important;
}
.jdgm-rev__rating .jdgm-star{
  color:#FFFFFF!important;
}
.jdgm-rev__author{
  color:#B3B3B3!important;
  font-size:11px!important;
  text-transform:uppercase!important;
  letter-spacing:0.1em!important;
}
.jdgm-rev__timestamp{
  color:#6E6E6E!important;
  font-size:10px!important;
}
.jdgm-rev__body{
  color:#B3B3B3!important;
  font-size:13px!important;
  line-height:1.8!important;
  font-style:italic!important;
}
.jdgm-rev__title{
  color:#FFFFFF!important;
  font-family:'Playfair Display',serif!important;
  font-weight:400!important;
}
.jdgm-paginate__page,
.jdgm-paginate__arrow{
  color:#FFFFFF!important;
  border-color:rgba(255,255,255,0.3)!important;
}
.jdgm-paginate__page.jdgm-paginate__page--active{
  background:#FFFFFF!important;
  color:#121212!important;
}
.jdgm-histogram__bar-fill{
  background:#FFFFFF!important;
}
.jdgm-summary-stars .jdgm-star{
  color:#FFFFFF!important;
}
.jdgm-write-rev-link{
  color:#FFFFFF!important;
  border:1px solid rgba(255,255,255,0.4)!important;
  border-radius:2px!important;
  font-size:11px!important;
  letter-spacing:0.12em!important;
  text-transform:uppercase!important;
}
.jdgm-write-rev-link:hover{
  background:#FFFFFF!important;
  color:#121212!important;
}

@media(max-width:900px){
  .pt-rv{padding:56px 24px}
  .pt-rv__header{flex-direction:column;align-items:flex-start;gap:12px}
}
</style>

{% schema %}
{
  "name": "Reviews",
  "settings": [],
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}


