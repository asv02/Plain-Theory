{% liquid
  assign care = product.metafields.custom.wash_care.value
%}

{% if care %}
<section class="pt-care">

  <div class="pt-care-header">
    <p class="pt-section-eyebrow">CARE GUIDE</p>
    <h2 class="pt-section-title">Keep it looking new.</h2>
  </div>

  <div class="pt-care-grid">

    <!-- Machine Wash -->
    <article class="pt-care-card">
      <div class="pt-care-icon">🧺</div>

      <div class="pt-care-content">
        <h4>Machine Wash</h4>
        <p>
          {% if care.machine_wash %}
            Machine wash
          {% else %}
            Hand wash only
          {% endif %}
        </p>
      </div>
    </article>

    <!-- Temperature -->
    <article class="pt-care-card">
      <div class="pt-care-icon">🌡️</div>

      <div class="pt-care-content">
        <h4>Temperature</h4>
        <p>{{ care.water_temperature | default: '30°C or below' }}</p>
      </div>
    </article>

    <!-- Drying -->
    <article class="pt-care-card">
      <div class="pt-care-icon">🌤️</div>

      <div class="pt-care-content">
        <h4>Drying</h4>
        <p>{{ care.drying | default: 'Air dry flat' }}</p>
      </div>
    </article>

    <!-- Bleach -->
    <article class="pt-care-card">
      <div class="pt-care-icon">🚫</div>

      <div class="pt-care-content">
        <h4>Bleach</h4>
        <p>{{ care.bleach | default: 'Do not bleach' }}</p>
      </div>
    </article>

    <!-- Iron -->
    <article class="pt-care-card">
      <div class="pt-care-icon">🧼</div>

      <div class="pt-care-content">
        <h4>Iron</h4>
        <p>{{ care.iron | default: 'Low heat only' }}</p>
      </div>
    </article>

  </div>

  {% if care.notes != blank %}
    <div class="pt-care-notes">
      <strong>Extra Care</strong>
      <p>{{ care.notes }}</p>
    </div>
  {% endif %}

</section>
{% endif %}