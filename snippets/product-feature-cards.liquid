{% liquid
  assign features = product.metafields.custom.features.value
%}

{% if features != blank %}

<section class="pt-features">

  <div class="pt-section-heading">

    <p class="pt-section-eyebrow">
      WHY YOU'LL LOVE IT
    </p>

    <h2 class="pt-section-title">
      Thoughtfully made.<br>
      Designed to be worn every day.
    </h2>

  </div>

  <div class="pt-feature-grid">

    {% for feature in features %}

      <article class="pt-feature-card">

        <div class="pt-feature-icon">

          {% if feature.image != blank %}

            <img
              src="{{ feature.image | image_url: width:80 }}"
              alt="{{ feature.title }}"
              loading="lazy"
              width="40"
              height="40"
            >

          {% endif %}

        </div>

        <div class="pt-feature-content">

          <h3>{{ feature.title }}</h3>

          <p>{{ feature.description }}</p>

        </div>

      </article>

    {% endfor %}

  </div>

</section>

{% endif %}