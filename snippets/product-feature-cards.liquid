{% liquid
  assign features = product.metafields.custom.features.value
%}

{% if features != blank %}
  <section class="pt-features">
    <div class="pt-section-heading">
      <p class="pt-section-eyebrow">WHY YOU'LL LOVE IT</p>

      <h2 class="pt-section-title">
        Thoughtfully made.<br>
        Designed to be worn every day.
      </h2>
    </div>

    <div class="pt-feature-grid">
      {% for feature in features %}
        <article class="pt-feature-card">
          <div class="pt-feature-icon">
            {% case feature.title %}
              {% when 'Breathable' %}
                🌬️

              {% when 'Naturally Soft' %}
                ☁️

              {% when 'Built to Last' %}
                🛡️

              {% when 'Comfortable All Day' %}
                ☀️

              {% when 'Better Color Retention' %}
                🎨

              {% when 'Skin-Friendly Feel' %}
                🌿

              {% else %}
                ✓
            {% endcase %}
          </div>

          <div class="pt-feature-content">
            <h3>{{ feature.title }}</h3>

            <p>{{ feature.description }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% endif %}
